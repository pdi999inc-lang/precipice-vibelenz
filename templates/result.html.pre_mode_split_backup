<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>VibeLenz Analysis</title>
  <style>
    :root {
      --bg: #071022;
      --panel: #0e1830;
      --panel-2: #111f3d;
      --border: #22355e;
      --text: #f4f7ff;
      --muted: #b3c0db;
      --low: #33d28b;
      --med: #f2b24d;
      --high: #ff6b6b;
      --chip: #17305e;
      --chip-good: rgba(51,210,139,0.14);
      --chip-warn: rgba(255,107,107,0.14);
      --shadow: 0 14px 34px rgba(0,0,0,0.25);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: linear-gradient(180deg, #061022 0%, #09142b 100%);
      color: var(--text);
    }

    .page {
      max-width: 1180px;
      margin: 0 auto;
      padding: 28px 18px 48px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: flex-start;
      margin-bottom: 20px;
    }

    .title {
      margin: 0 0 8px;
      font-size: 32px;
      font-weight: 800;
      letter-spacing: -0.4px;
    }

    .subtle {
      color: var(--muted);
      font-size: 14px;
      margin-bottom: 4px;
    }

    .badge {
      display: inline-block;
      padding: 10px 16px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.4px;
    }

    .badge.low { background: rgba(51,210,139,0.16); color: var(--low); }
    .badge.medium { background: rgba(242,178,77,0.16); color: var(--med); }
    .badge.high { background: rgba(255,107,107,0.16); color: var(--high); }

    .hero {
      background: linear-gradient(180deg, var(--panel), var(--panel-2));
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 24px;
      box-shadow: var(--shadow);
      margin-bottom: 22px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 160px 1fr;
      gap: 22px;
      align-items: center;
    }

    .score-box {
      border-right: 1px solid var(--border);
      padding-right: 20px;
      text-align: center;
    }

    .score {
      font-size: 74px;
      font-weight: 800;
      line-height: 1;
      margin-bottom: 8px;
    }

    .score-label {
      color: var(--muted);
      font-size: 14px;
    }

    .hero-copy h2 {
      font-size: 28px;
      margin: 0 0 10px;
      letter-spacing: -0.3px;
    }

    .hero-copy p {
      margin: 0;
      color: var(--muted);
      font-size: 15px;
      line-height: 1.6;
    }

    .meta-grid,
    .grid-2 {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      margin-top: 18px;
    }

    .mini-card,
    .section {
      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 20px;
    }

    .mini-label {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.6px;
      margin-bottom: 8px;
    }

    .mini-value {
      font-size: 18px;
      font-weight: 800;
    }

    .section {
      margin-bottom: 18px;
    }

    .section h3 {
      margin: 0 0 14px;
      font-size: 22px;
      letter-spacing: -0.2px;
    }

    .section p {
      margin: 0;
      font-size: 16px;
      line-height: 1.7;
      color: var(--text);
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .chip {
      display: inline-flex;
      align-items: center;
      padding: 10px 14px;
      border-radius: 999px;
      background: var(--chip);
      border: 1px solid #35558f;
      font-size: 14px;
      font-weight: 700;
      color: #dce7ff;
    }

    .chip.good {
      background: var(--chip-good);
      border-color: rgba(51,210,139,0.35);
      color: #bdf3da;
    }

    .chip.warn {
      background: var(--chip-warn);
      border-color: rgba(255,107,107,0.35);
      color: #ffd1d1;
    }

    .machine {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    .machine-card {
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px;
    }

    .machine-card .k {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 6px;
    }

    .machine-card .v {
      font-size: 16px;
      font-weight: 800;
      word-break: break-word;
    }

    pre {
      margin: 0;
      white-space: pre-wrap;
      word-break: break-word;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.6;
    }

    .footer-link {
      color: #9fc2ff;
      text-decoration: none;
      font-size: 14px;
    }

    @media (max-width: 860px) {
      .hero-grid,
      .meta-grid,
      .grid-2,
      .machine {
        grid-template-columns: 1fr;
      }

      .score-box {
        border-right: none;
        border-bottom: 1px solid var(--border);
        padding-right: 0;
        padding-bottom: 18px;
      }

      .title {
        font-size: 26px;
      }

      .score {
        font-size: 58px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    {% set badge = (risk_level or risk_label or 'LOW')|lower %}

    <div class="topbar">
      <div>
        <h1 class="title">VibeLenz Analysis</h1>
        <div class="subtle">Request ID: {{ request_id }}</div>
        <div class="subtle">Machine lane: {{ lane or "Unknown" }} · Machine label: {{ primary_label or "Unknown" }}</div>
      </div>
      <div>
        <span class="badge {% if badge.startswith('high') %}high{% elif badge.startswith('med') %}medium{% else %}low{% endif %}">
          {{ risk_level or risk_label or "LOW" }}
        </span>
      </div>
    </div>

    <div class="hero">
      <div class="hero-grid">
        <div class="score-box">
          <div class="score">{{ final_risk_score if final_risk_score is not none else risk_score }}</div>
          <div class="score-label">Risk Score</div>
        </div>

        <div class="hero-copy">
          <h2>{{ diagnosis or summary or "Analysis complete." }}</h2>
          <p>{{ reasoning or summary_logic or "No additional reasoning available." }}</p>

          <div class="meta-grid">
            <div class="mini-card">
              <div class="mini-label">Human read</div>
              <div class="mini-value">{{ human_label or "No human label" }}</div>
            </div>
            <div class="mini-card">
              <div class="mini-label">Domain</div>
              <div class="mini-value">{{ domain_mode or "Unknown" }}</div>
            </div>
            <div class="mini-card">
              <div class="mini-label">Confidence</div>
              <div class="mini-value">{{ confidence }}</div>
            </div>
            <div class="mini-card">
              <div class="mini-label">Best-fit mode</div>
              <div class="mini-value">{{ analysis_mode or "Unknown" }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid-2">
      <div class="section">
        <h3>What this looks like</h3>
        <p>{{ diagnosis or "No diagnosis available." }}</p>
      </div>

      <div class="section">
        <h3>Why it reads that way</h3>
        <p>{{ reasoning or summary_logic or "No reasoning available." }}</p>
      </div>
    </div>

    <div class="grid-2">
      <div class="section">
        <h3>Best next move</h3>
        <p>{{ practical_next_steps or recommended_action or "No next steps available." }}</p>
      </div>

      <div class="section">
        <h3>Keep yourself honest</h3>
        <p>{{ accountability or "No accountability guidance available." }}</p>
      </div>
    </div>

    <div class="section">
      <h3>Signals that pushed risk up</h3>
      <div class="chips">
        {% if key_signals and key_signals|length > 0 and key_signals[0] != "No signals detected" %}
          {% for item in key_signals %}
            <span class="chip warn">{{ item|replace('_', ' ')|title }}</span>
          {% endfor %}
        {% else %}
          <span class="chip">None that strongly raise concern here</span>
        {% endif %}
      </div>
    </div>

    <div class="section">
      <h3>What kept this from reading worse</h3>
      <div class="chips">
        {% if key_dampeners %}
          {% for item in key_dampeners %}
            <span class="chip good">{{ item|replace('_', ' ')|title }}</span>
          {% endfor %}
        {% else %}
          <span class="chip">No dampeners surfaced</span>
        {% endif %}
      </div>
    </div>

    <div class="section">
      <h3>Other plausible reads</h3>
      <div class="chips">
        {% if alternative_explanations %}
          {% for item in alternative_explanations %}
            <span class="chip">{{ item|replace('_', ' ')|title }}</span>
          {% endfor %}
        {% else %}
          <span class="chip">None surfaced</span>
        {% endif %}
      </div>
    </div>

    {% if contradiction_signals %}
    <div class="section">
      <h3>Contradiction signals</h3>
      <div class="chips">
        {% for item in contradiction_signals %}
          <span class="chip warn">{{ item.type|replace('_', ' ')|title }}</span>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    <div class="section">
      <h3>Machine detail</h3>
      <div class="machine">
        <div class="machine-card">
          <div class="k">Lane</div>
          <div class="v">{{ lane or "Unknown" }}</div>
        </div>
        <div class="machine-card">
          <div class="k">Primary label</div>
          <div class="v">{{ primary_label or "Unknown" }}</div>
        </div>
        <div class="machine-card">
          <div class="k">Intent horizon</div>
          <div class="v">{{ intent_horizon or "Unknown" }}</div>
        </div>
        <div class="machine-card">
          <div class="k">Pressure present</div>
          <div class="v">{{ pressure_present }}</div>
        </div>
        <div class="machine-card">
          <div class="k">Extraction present</div>
          <div class="v">{{ extraction_present }}</div>
        </div>
        <div class="machine-card">
          <div class="k">VIE action</div>
          <div class="v">{{ vie_action or "NONE" }}</div>
        </div>
        <div class="machine-card">
          <div class="k">Reciprocity level</div>
          <div class="v">{{ reciprocity_level or "Unknown" }}</div>
        </div>
        <div class="machine-card">
          <div class="k">Narrative integrity score</div>
          <div class="v">{{ narrative_integrity_score }}</div>
        </div>
        <div class="machine-card">
          <div class="k">Request ID</div>
          <div class="v">{{ request_id }}</div>
        </div>
      </div>
    </div>

    <div class="section">
      <h3>Extracted text</h3>
      <pre>{{ extracted_text }}</pre>
    </div>

    <a class="footer-link" href="/">← Analyze another conversation</a>
  </div>
</body>
</html>
