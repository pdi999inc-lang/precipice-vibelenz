<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>VibeLenz Analysis</title>
  <style>
    :root {
      --bg: #071022;
      --panel: #0e1830;
      --panel-2: #101d39;
      --border: #243b67;
      --text: #f5f8ff;
      --muted: #b8c4dc;
      --low: #3ddc97;
      --med: #f2b24d;
      --high: #ff7171;
      --blue: #75a8ff;
      --chip: #17305e;
      --chip-good: rgba(61,220,151,0.14);
      --chip-warn: rgba(255,113,113,0.14);
      --shadow: 0 18px 40px rgba(0,0,0,0.28);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: linear-gradient(180deg, #061021 0%, #09142b 100%);
      color: var(--text);
    }

    .page {
      max-width: 1120px;
      margin: 0 auto;
      padding: 28px 18px 50px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: flex-start;
      margin-bottom: 20px;
    }

    .title {
      margin: 0 0 8px;
      font-size: 32px;
      font-weight: 800;
      letter-spacing: -0.4px;
    }

    .subtle {
      color: var(--muted);
      font-size: 14px;
      margin-bottom: 4px;
    }

    .badge {
      display: inline-block;
      padding: 10px 16px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.4px;
    }

    .badge.low { background: rgba(61,220,151,0.16); color: var(--low); }
    .badge.medium { background: rgba(242,178,77,0.16); color: var(--med); }
    .badge.high { background: rgba(255,113,113,0.16); color: var(--high); }

    .hero {
      background: linear-gradient(180deg, var(--panel), var(--panel-2));
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 24px;
      box-shadow: var(--shadow);
      margin-bottom: 20px;
    }

    .eyebrow {
      color: var(--blue);
      font-size: 13px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.7px;
      margin-bottom: 8px;
    }

    .hero h2 {
      margin: 0 0 10px;
      font-size: 30px;
      line-height: 1.2;
      letter-spacing: -0.4px;
    }

    .hero p {
      margin: 0;
      font-size: 16px;
      line-height: 1.75;
      color: var(--muted);
    }

    .hero-top {
      display: grid;
      grid-template-columns: 150px 1fr;
      gap: 18px;
      align-items: start;
    }

    .score-box {
      border: 1px solid var(--border);
      border-radius: 20px;
      background: rgba(255,255,255,0.02);
      padding: 18px;
      text-align: center;
    }

    .score-num {
      font-size: 58px;
      font-weight: 800;
      line-height: 1;
      margin-bottom: 6px;
    }

    .score-label {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .meta-grid,
    .grid-2 {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      margin-top: 18px;
    }

    .mini-card,
    .section {
      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 20px;
    }

    .mini-label {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.6px;
      margin-bottom: 8px;
    }

    .mini-value {
      font-size: 18px;
      font-weight: 800;
    }

    .note {
      margin-top: 14px;
      padding: 14px 16px;
      border-radius: 16px;
      border: 1px solid rgba(242,178,77,0.32);
      background: rgba(242,178,77,0.08);
      color: #ffe2b0;
      font-size: 14px;
      line-height: 1.6;
    }

    .section {
      margin-bottom: 18px;
    }

    .section h3 {
      margin: 0 0 14px;
      font-size: 24px;
      letter-spacing: -0.2px;
    }

    .section p {
      margin: 0;
      font-size: 17px;
      line-height: 1.75;
      color: var(--text);
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .chip {
      display: inline-flex;
      align-items: center;
      padding: 10px 14px;
      border-radius: 999px;
      background: var(--chip);
      border: 1px solid #375a93;
      font-size: 14px;
      font-weight: 700;
      color: #deebff;
    }

    .chip.good {
      background: var(--chip-good);
      border-color: rgba(61,220,151,0.35);
      color: #c6f7df;
    }

    .chip.warn {
      background: var(--chip-warn);
      border-color: rgba(255,113,113,0.35);
      color: #ffd6d6;
    }

    details {
      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 16px 18px;
      margin-bottom: 18px;
    }

    details summary {
      cursor: pointer;
      font-weight: 800;
      font-size: 18px;
      outline: none;
    }

    .machine {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
      margin-top: 14px;
    }

    .machine-card {
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px;
    }

    .machine-card .k {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 6px;
    }

    .machine-card .v {
      font-size: 15px;
      font-weight: 800;
      word-break: break-word;
    }

    pre {
      margin: 12px 0 0;
      white-space: pre-wrap;
      word-break: break-word;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.6;
    }

    .footer-link {
      color: #a8c8ff;
      text-decoration: none;
      font-size: 14px;
    }

    @media (max-width: 860px) {
      .hero-top,
      .meta-grid,
      .grid-2,
      .machine {
        grid-template-columns: 1fr;
      }

      .title {
        font-size: 26px;
      }

      .hero h2 {
        font-size: 24px;
      }

      .score-num {
        font-size: 46px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    {% set badge = (risk_level or risk_label or 'LOW')|lower %}

    <div class="topbar">
      <div>
        <h1 class="title">{{ mode_title or "VibeLenz Analysis" }}</h1>
        <div class="subtle">Request ID: {{ request_id }}</div>
        <div class="subtle">Requested mode: {{ requested_mode or "unknown" }} · Presentation mode: {{ presentation_mode or "unknown" }}</div>
        <div class="subtle">{{ mode_tagline or "Conversation analysis" }}</div>
      </div>
      <div>
        <span class="badge {% if badge.startswith('high') %}high{% elif badge.startswith('med') %}medium{% else %}low{% endif %}">
          {{ risk_level or risk_label or "LOW" }}
        </span>
      </div>
    </div>

    <div class="hero">
      <div class="hero-top">
        {% if presentation_mode == "risk" %}
        <div class="score-box">
          <div class="score-num">{{ final_risk_score if final_risk_score is not none else risk_score }}</div>
          <div class="score-label">Risk score</div>
        </div>
        {% else %}
        <div class="score-box">
          <div class="score-num">{{ interest_score if interest_score is not none else final_risk_score if final_risk_score is not none else risk_score }}</div>
          <div class="score-label">{% if interest_score is not none %}Connection score{% else %}Caution level{% endif %}</div>
        </div>
        {% endif %}

        <div>
          <div class="eyebrow">
            {% if presentation_mode == "connection" %}
              What’s really going on
            {% else %}
              Risk summary
            {% endif %}
          </div>
          <h2>{{ diagnosis or summary or "Analysis complete." }}</h2>
          <p>{{ reasoning or summary_logic or "No additional reasoning available." }}</p>

          {% if mode_override_note %}
          <div class="note">{{ mode_override_note }}</div>
          {% endif %}
        </div>
      </div>

      <div class="meta-grid">
        {% if presentation_mode == "connection" %}
          <div class="mini-card">
            <div class="mini-label">Overall feel</div>
            <div class="mini-value">{{ human_label or "low-stakes interaction" }}</div>
          </div>
          <div class="mini-card">
            <div class="mini-label">Interest / receptivity</div>
            <div class="mini-value">{{ interest_summary or "context dependent" }}</div>
          </div>
          <div class="mini-card">
            <div class="mini-label">Social tone</div>
            <div class="mini-value">{{ social_tone or "fairly low-stakes" }}</div>
          </div>
          <div class="mini-card">
            <div class="mini-label">Confidence</div>
            <div class="mini-value">{{ confidence }}</div>
          </div>
        {% else %}
          <div class="mini-card">
            <div class="mini-label">Human read</div>
            <div class="mini-value">{{ human_label or "risk pattern" }}</div>
          </div>
          <div class="mini-card">
            <div class="mini-label">Domain</div>
            <div class="mini-value">{{ domain_mode or "Unknown" }}</div>
          </div>
          <div class="mini-card">
            <div class="mini-label">Confidence</div>
            <div class="mini-value">{{ confidence }}</div>
          </div>
          <div class="mini-card">
            <div class="mini-label">Action bias</div>
            <div class="mini-value">{{ vie_action or "NONE" }}</div>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="grid-2">
      <div class="section">
        <h3>
          {% if presentation_mode == "connection" %}
            What this feels like
          {% else %}
            What it points to
          {% endif %}
        </h3>
        <p>{{ diagnosis or "No diagnosis available." }}</p>
      </div>

      <div class="section">
        <h3>
          {% if presentation_mode == "connection" %}
            Why it feels that way
          {% else %}
            Why it was flagged
          {% endif %}
        </h3>
        <p>{{ reasoning or summary_logic or "No reasoning available." }}</p>
      </div>
    </div>

    <div class="grid-2">
      <div class="section">
        <h3>
          {% if presentation_mode == "connection" %}
            Best next move
          {% else %}
            Recommended action
          {% endif %}
        </h3>
        <p>{{ practical_next_steps or recommended_action or "No next steps available." }}</p>
      </div>

      <div class="section">
        <h3>
          {% if presentation_mode == "connection" %}
            Don’t sabotage it by…
          {% else %}
            Keep yourself honest
          {% endif %}
        </h3>
        <p>{{ accountability or "No accountability guidance available." }}</p>
      </div>
    </div>

    {% if presentation_mode == "connection" %}
    <div class="section">
      <h3>What feels positive here</h3>
      <div class="chips">
        {% if positive_signals %}
          {% for item in positive_signals %}
            <span class="chip good">{{ item|replace('_', ' ')|title }}</span>
          {% endfor %}
        {% else %}
          <span class="chip">No strong positive cues surfaced</span>
        {% endif %}
      </div>
    </div>
    {% endif %}

    <div class="section">
      <h3>
        {% if presentation_mode == "connection" %}
          What raised concern
        {% else %}
          What raises concern
        {% endif %}
      </h3>
      <div class="chips">
        {% if key_signals and key_signals|length > 0 and key_signals[0] != "No signals detected" %}
          {% for item in key_signals %}
            <span class="chip warn">{{ item|replace('_', ' ')|title }}</span>
          {% endfor %}
        {% else %}
          <span class="chip">
            {% if presentation_mode == "connection" %}
              Nothing here strongly raises concern
            {% else %}
              No strong risk signals surfaced
            {% endif %}
          </span>
        {% endif %}
      </div>
    </div>

    <div class="section">
      <h3>
        {% if presentation_mode == "connection" %}
          What kept this from reading worse
        {% else %}
          What lowers concern
        {% endif %}
      </h3>
      <div class="chips">
        {% if key_dampeners %}
          {% for item in key_dampeners %}
            <span class="chip good">{{ item|replace('_', ' ')|title }}</span>
          {% endfor %}
        {% else %}
          <span class="chip">No dampeners surfaced</span>
        {% endif %}
      </div>
    </div>

    <div class="section">
      <h3>Other plausible reads</h3>
      <div class="chips">
        {% if alternative_explanations %}
          {% for item in alternative_explanations %}
            <span class="chip">{{ item|replace('_', ' ')|title }}</span>
          {% endfor %}
        {% else %}
          <span class="chip">None surfaced</span>
        {% endif %}
      </div>
    </div>

    {% if contradiction_signals %}
    <div class="section">
      <h3>Contradiction signals</h3>
      <div class="chips">
        {% for item in contradiction_signals %}
          <span class="chip warn">{{ item.type|replace('_', ' ')|title }}</span>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    <details>
      <summary>Show machine detail</summary>
      <div class="machine">
        <div class="machine-card">
          <div class="k">Lane</div>
          <div class="v">{{ lane or "Unknown" }}</div>
        </div>
        <div class="machine-card">
          <div class="k">Primary label</div>
          <div class="v">{{ primary_label or "Unknown" }}</div>
        </div>
        <div class="machine-card">
          <div class="k">Intent horizon</div>
          <div class="v">{{ intent_horizon or "Unknown" }}</div>
        </div>
        <div class="machine-card">
          <div class="k">Pressure present</div>
          <div class="v">{{ pressure_present }}</div>
        </div>
        <div class="machine-card">
          <div class="k">Extraction present</div>
          <div class="v">{{ extraction_present }}</div>
        </div>
        <div class="machine-card">
          <div class="k">VIE action</div>
          <div class="v">{{ vie_action or "NONE" }}</div>
        </div>
        <div class="machine-card">
          <div class="k">Reciprocity level</div>
          <div class="v">{{ reciprocity_level or "Unknown" }}</div>
        </div>
        <div class="machine-card">
          <div class="k">Narrative integrity score</div>
          <div class="v">{{ narrative_integrity_score }}</div>
        </div>
        <div class="machine-card">
          <div class="k">Requested mode</div>
          <div class="v">{{ requested_mode or "risk" }}</div>
        </div>
      </div>

      <pre>{{ extracted_text }}</pre>
    </details>

    <a class="footer-link" href="/">← Analyze another conversation</a>
  </div>
</body>
</html>
